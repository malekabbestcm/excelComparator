{"file":"results-Cbphxx3f.js","mappings":";;;;;;;;;;;;;;;;;;;AAyEA,UAAM,QAAQ,cAAA;AACd,UAAM,mBAAmB,SAAS,MAAM,MAAM,gBAAgB;AAE9D,UAAM,aAAa,SAAS,MAAM;AAChC,aAAO,iBAAiB,OAAO,MAAM,OAAO,UAAU;AAAA,IACxD,CAAC;AAED,UAAM,eAAe,SAAS,MAAM;AAClC,aAAO,iBAAiB,OAAO,MAAM,SAAS,UAAU;AAAA,IAC1D,CAAC;AAED,UAAM,eAAe,SAAS,MAAM;AAClC,aAAO,iBAAiB,OAAO,MAAM,SAAS,UAAU;AAAA,IAC1D,CAAC;;mBArFMA,eAAAC,WAAA,EAAA,OAAM,4BAAA,GAA2B,MAAA,CAAA,+NAOzBC,MAAA,UAAA,CAAU,glBAsBVA,MAAA,YAAA,CAAY,6jBAsBZA,MAAA,YAAA,CAAY;;;;;;;;;;;;;;ACkG3B,UAAM,QAAQ,cAAA;AACd,UAAM,mBAAmB,SAAS,MAAM,MAAM,gBAAgB;AAE9D,UAAM,mBAAmB,IAAI;AAAA,MAC3B,OAAO;AAAA,MACP,SAAS;AAAA,MACT,SAAS;AAAA,IAAA,CACV;AAED,UAAM,aAAa,SAAS,MAAM;AAChC,aAAO,iBAAiB,OAAO,MAAM,SAAS,CAAA;AAAA,IAChD,CAAC;AAED,UAAM,eAAe,SAAS,MAAM;AAClC,aAAO,iBAAiB,OAAO,MAAM,WAAW,CAAA;AAAA,IAClD,CAAC;AAED,UAAM,uBAAuB,CAAC,SAAc;AAC1C,UAAI,CAAC,QAAQ,OAAO,SAAS,SAAU,QAAO,EAAE,KAAK,MAAM,SAAS,CAAA,GAAI,QAAQ,MAAM,OAAO,KAAA;AAE7F,YAAM,MAAM,KAAK,OAAO,KAAK,MAAM,KAAK,MAAM,KAAK,QAAQ,KAAK,OAAO;AACvE,YAAM,UAAU,MAAM,QAAQ,KAAK,OAAO,IAAI,KAAK,UAAU,MAAM,QAAQ,KAAK,IAAI,IAAI,KAAK,OAAO,CAAA;AACpG,YAAM,SAAS,KAAK,UAAU,KAAK,QAAQ,KAAK,KAAK,KAAK,YAAY,KAAK,QAAQ,KAAK,OAAO;AAC/F,YAAM,QAAQ,KAAK,SAAS,KAAK,QAAQ,KAAK,KAAK,KAAK,YAAY,KAAK,MAAM,KAAK,OAAO;AAE3F,aAAO,EAAE,GAAG,MAAM,KAAK,SAAS,QAAQ,MAAA;AAAA,IAC1C;AAEA,UAAM,eAAe,SAAS,MAAM;AAClC,YAAM,MAAM,iBAAiB,OAAO,MAAM,WAAW,CAAA;AACrD,aAAO,IAAI,IAAI,oBAAoB;AAAA,IACrC,CAAC;AAED,UAAM,YAAY,SAAS,MAAM;AAC/B,aAAO,WAAW,MAAM,WAAW,KAC5B,aAAa,MAAM,WAAW,KAC9B,aAAa,MAAM,WAAW;AAAA,IACvC,CAAC;AAMD,UAAM,aAAa,CAAC,QAAqB;AACvC,UAAI;AACF,eAAO,KAAK,UAAU,KAAK,MAAM,CAAC;AAAA,MACpC,QAAQ;AACN,eAAO,OAAO,GAAG;AAAA,MACnB;AAAA,IACF;AAGA,UAAM,YAAY,MAAM;AACtB,uBAAiB,QAAQ;AAAA,QACvB,OAAO;AAAA,QACP,SAAS;AAAA,QACT,SAAS;AAAA,MAAA;AAAA,IAEb;AAEA,UAAM,cAAc,MAAM;AACxB,uBAAiB,QAAQ;AAAA,QACvB,OAAO;AAAA,QACP,SAAS;AAAA,QACT,SAAS;AAAA,MAAA;AAAA,IAEb;AAGA,aAAa;AAAA,MACX;AAAA,MACA;AAAA,IAAA,CACD;;AA7NM,YAAA,OAAAF,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,CAAA,GAAA;AAET,UAAAC,MAAA,UAAA,EAAW,SAAM,GAAA;gdASNC,eAAAD,MAAA,UAAA,EAAW,MAAM,yBAITE,eAAA,CAAA,EAAA,cAAAF,MAAA,gBAAA,EAAiB,MAAA,GAAK,wCAAA,CAAA,4MAQrCG,eAAAH,MAAA,gBAAA,EAAiB,QAAK,OAAA,EAAA,SAAA,OAAA,CAAA;sBAGLA,MAAA,UAAA,GAAU,CAA1B,MAAM,UAAK;AAIoC,gBAAA,uHAAAC,eAAA,WAAW,IAAI,CAAA,CAAA,cAAA;AAAA;;;;;AAOnE,UAAAD,MAAA,YAAA,EAAa,SAAM,GAAA;wbASNC,eAAAD,MAAA,YAAA,EAAa,MAAM,yBAIbE,eAAA,CAAA,EAAA,cAAAF,MAAA,gBAAA,EAAiB,QAAA,GAAO,wCAAA,CAAA,4MAQvCG,eAAAH,MAAA,gBAAA,EAAiB,UAAO,OAAA,EAAA,SAAA,OAAA,CAAA;sBAGPA,MAAA,YAAA,GAAY,CAA5B,MAAM,UAAK;AAIkC,gBAAA,iHAAAC,eAAA,WAAW,IAAI,CAAA,CAAA,cAAA;AAAA;;;;;AAOjE,UAAAD,MAAA,YAAA,EAAa,SAAM,GAAA;weASNC,eAAAD,MAAA,YAAA,EAAa,MAAM,yBAIbE,eAAA,CAAA,EAAA,cAAAF,MAAA,gBAAA,EAAiB,QAAA,GAAO,wCAAA,CAAA,4MAQvCG,eAAAH,MAAA,gBAAA,EAAiB,UAAO,OAAA,EAAA,SAAA,OAAA,CAAA;sBAGPA,MAAA,YAAA,GAAY,CAA5B,MAAM,UAAK;;AAIR,cAAA,KAAK,KAAG;AACwC,kBAAA,2EAAAC,eAAA,KAAK,GAAG,CAAA,eAAA;AAAA;;;AAExD,cAAA,KAAK,WAAW,KAAK,QAAQ,QAAM;;AAIRG,0BAAA,KAAK,SAAO,CAApC,QAAQ,gBAAW;oFAIEH,eAAA,OAAO,KAAK,2DACN,WAAW,OAAO,IAAI,CAAA,kFAEzB,WAAW,OAAO,EAAE,CAAA;;;;;;yOAO2C,WAAW,KAAK,MAAM,CAAA,oMAIhB,WAAW,KAAK,KAAK,CAAA;;;;;;UAS7HD,MAAA,SAAA,GAAS;;;;;;;;;;;;;;;;;;;;ACCxB,UAAM,QAAQ,cAAA;AACd,UAAM,QAAQ,SAAS,MAAM,MAAM,KAAK;AACxC,UAAM,mBAAmB,SAAS,MAAM,MAAM,gBAAgB;AAG9D,QAAI,CAAC,iBAAiB,OAAO;AAC3B,OAAA,QAAA,SAAA,IAAAK,iBAAA,MAAM,WAAW,GAAG,CAAA;IACtB;;;;AA9IO,YAAA,OAAAP,eAAAC,WAAA,EAAA,OAAM,+DAA2D,MAAA,CAAA,CAAA,8lDAAA;AAqDpD,YAAAO,mBAAA,yBAAA,EAAA,OAAM,UAAM,MAAA,OAAA,CAAA;;;;AAmCDF,oBAAAJ,MAAA,KAAA,IAAR,SAAI;qdASJC,eAAA,KAAK,IAAI,wDAGTD,MAAA,cAAA,EAAe,KAAK,IAAI,CAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_ssrRenderClass","_ssrRenderStyle","_ssrRenderList","_withAsyncContext","_ssrRenderComponent"],"sources":["../../../../components/SummaryCards.vue","../../../../components/DiffViewer.vue","../../../../pages/results.vue"],"sourcesContent":["<template>\n  <div class=\"grid md:grid-cols-3 gap-6\">\n    <!-- Added Items Card -->\n    <div class=\"card border-l-4 border-green-500\">\n      <div class=\"flex items-center justify-between\">\n        <div>\n          <p class=\"text-sm font-medium text-gray-600\">Added Items</p>\n          <p class=\"text-3xl font-bold text-green-600\">\n            {{ addedCount }}\n          </p>\n        </div>\n        <div class=\"bg-green-100 rounded-full p-3\">\n          <svg class=\"h-8 w-8 text-green-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" />\n          </svg>\n        </div>\n      </div>\n      <div class=\"mt-4\">\n        <p class=\"text-sm text-gray-600\">\n          New items found in the second file\n        </p>\n      </div>\n    </div>\n\n    <!-- Removed Items Card -->\n    <div class=\"card border-l-4 border-red-500\">\n      <div class=\"flex items-center justify-between\">\n        <div>\n          <p class=\"text-sm font-medium text-gray-600\">Removed Items</p>\n          <p class=\"text-3xl font-bold text-red-600\">\n            {{ removedCount }}\n          </p>\n        </div>\n        <div class=\"bg-red-100 rounded-full p-3\">\n          <svg class=\"h-8 w-8 text-red-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20 12H4\" />\n          </svg>\n        </div>\n      </div>\n      <div class=\"mt-4\">\n        <p class=\"text-sm text-gray-600\">\n          Items removed from the first file\n        </p>\n      </div>\n    </div>\n\n    <!-- Changed Items Card -->\n    <div class=\"card border-l-4 border-amber-500\">\n      <div class=\"flex items-center justify-between\">\n        <div>\n          <p class=\"text-sm font-medium text-gray-600\">Changed Items</p>\n          <p class=\"text-3xl font-bold text-amber-600\">\n            {{ changedCount }}\n          </p>\n        </div>\n        <div class=\"bg-amber-100 rounded-full p-3\">\n          <svg class=\"h-8 w-8 text-amber-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4\" />\n          </svg>\n        </div>\n      </div>\n      <div class=\"mt-4\">\n        <p class=\"text-sm text-gray-600\">\n          Items modified between files\n        </p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { useFilesStore } from '~/stores/files'\n\nconst store = useFilesStore()\nconst comparisonResult = computed(() => store.comparisonResult)\n\nconst addedCount = computed(() => {\n  return comparisonResult.value?.data?.added?.length || 0\n})\n\nconst removedCount = computed(() => {\n  return comparisonResult.value?.data?.removed?.length || 0\n})\n\nconst changedCount = computed(() => {\n  return comparisonResult.value?.data?.changed?.length || 0\n})\n</script>\n","<template>\n  <div class=\"space-y-4\">\n    <!-- Added Items -->\n    <div v-if=\"addedItems.length > 0\" class=\"border border-green-200 rounded-lg overflow-hidden\">\n      <button\n        @click=\"toggleSection('added')\"\n        class=\"w-full px-4 py-3 bg-green-50 text-green-800 font-medium flex items-center justify-between hover:bg-green-100 transition-colors\"\n      >\n        <span class=\"flex items-center\">\n          <svg class=\"h-5 w-5 mr-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" />\n          </svg>\n          Added Items ({{ addedItems.length }})\n        </span>\n        <svg\n          class=\"h-5 w-5 transform transition-transform\"\n          :class=\"{ 'rotate-180': expandedSections.added }\"\n          fill=\"none\"\n          viewBox=\"0 0 24 24\"\n          stroke=\"currentColor\"\n        >\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n        </svg>\n      </button>\n      <div v-show=\"expandedSections.added\" class=\"bg-white p-4\">\n        <div class=\"space-y-2 max-h-96 overflow-y-auto\">\n          <div\n            v-for=\"(item, index) in addedItems\"\n            :key=\"`added-${index}`\"\n            class=\"p-3 bg-green-50 border border-green-200 rounded-lg\"\n          >\n            <pre class=\"text-sm text-green-800 overflow-x-auto\">{{ formatJson(item) }}</pre>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Removed Items -->\n    <div v-if=\"removedItems.length > 0\" class=\"border border-red-200 rounded-lg overflow-hidden\">\n      <button\n        @click=\"toggleSection('removed')\"\n        class=\"w-full px-4 py-3 bg-red-50 text-red-800 font-medium flex items-center justify-between hover:bg-red-100 transition-colors\"\n      >\n        <span class=\"flex items-center\">\n          <svg class=\"h-5 w-5 mr-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20 12H4\" />\n          </svg>\n          Removed Items ({{ removedItems.length }})\n        </span>\n        <svg\n          class=\"h-5 w-5 transform transition-transform\"\n          :class=\"{ 'rotate-180': expandedSections.removed }\"\n          fill=\"none\"\n          viewBox=\"0 0 24 24\"\n          stroke=\"currentColor\"\n        >\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n        </svg>\n      </button>\n      <div v-show=\"expandedSections.removed\" class=\"bg-white p-4\">\n        <div class=\"space-y-2 max-h-96 overflow-y-auto\">\n          <div\n            v-for=\"(item, index) in removedItems\"\n            :key=\"`removed-${index}`\"\n            class=\"p-3 bg-red-50 border border-red-200 rounded-lg\"\n          >\n            <pre class=\"text-sm text-red-800 overflow-x-auto\">{{ formatJson(item) }}</pre>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Changed Items -->\n    <div v-if=\"changedItems.length > 0\" class=\"border border-amber-200 rounded-lg overflow-hidden\">\n      <button\n        @click=\"toggleSection('changed')\"\n        class=\"w-full px-4 py-3 bg-amber-50 text-amber-800 font-medium flex items-center justify-between hover:bg-amber-100 transition-colors\"\n      >\n        <span class=\"flex items-center\">\n          <svg class=\"h-5 w-5 mr-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4\" />\n          </svg>\n          Changed Items ({{ changedItems.length }})\n        </span>\n        <svg\n          class=\"h-5 w-5 transform transition-transform\"\n          :class=\"{ 'rotate-180': expandedSections.changed }\"\n          fill=\"none\"\n          viewBox=\"0 0 24 24\"\n          stroke=\"currentColor\"\n        >\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n        </svg>\n      </button>\n      <div v-show=\"expandedSections.changed\" class=\"bg-white p-4\">\n        <div class=\"space-y-4 max-h-96 overflow-y-auto\">\n          <div\n            v-for=\"(item, index) in changedItems\"\n            :key=\"`changed-${index}`\"\n            class=\"p-3 bg-amber-50 border border-amber-200 rounded-lg\"\n          >\n            <div v-if=\"item.key\" class=\"mb-2\">\n              <span class=\"text-sm font-medium text-amber-800\">Key: {{ item.key }}</span>\n            </div>\n            <div v-if=\"item.changes && item.changes.length\" class=\"mb-3\">\n              <p class=\"text-xs font-medium text-gray-600 mb-1\">Changes:</p>\n              <div class=\"space-y-1\">\n                <div\n                  v-for=\"(change, changeIndex) in item.changes\"\n                  :key=\"`change-${index}-${changeIndex}`\"\n                  class=\"text-xs text-gray-700\"\n                >\n                  <span class=\"font-medium\">{{ change.field }}:</span>\n                  <span class=\"text-red-700 ml-1\">{{ formatJson(change.from) }}</span>\n                  <span class=\"mx-1\">→</span>\n                  <span class=\"text-green-700\">{{ formatJson(change.to) }}</span>\n                </div>\n              </div>\n            </div>\n            <div class=\"grid md:grid-cols-2 gap-4\">\n              <div>\n                <p class=\"text-xs font-medium text-gray-600 mb-1\">Before:</p>\n                <pre class=\"text-sm text-red-700 bg-red-50 p-2 rounded border border-red-200 overflow-x-auto\">{{ formatJson(item.before) }}</pre>\n              </div>\n              <div>\n                <p class=\"text-xs font-medium text-gray-600 mb-1\">After:</p>\n                <pre class=\"text-sm text-green-700 bg-green-50 p-2 rounded border border-green-200 overflow-x-auto\">{{ formatJson(item.after) }}</pre>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- No Changes Message -->\n    <div v-if=\"noChanges\" class=\"text-center py-12\">\n      <div class=\"bg-gray-50 rounded-lg p-8\">\n        <svg class=\"mx-auto h-12 w-12 text-gray-400 mb-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" />\n        </svg>\n        <h3 class=\"text-lg font-medium text-gray-900 mb-2\">No Changes Found</h3>\n        <p class=\"text-gray-600\">The files appear to be identical or contain no comparable data.</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { useFilesStore } from '~/stores/files'\n\nconst store = useFilesStore()\nconst comparisonResult = computed(() => store.comparisonResult)\n\nconst expandedSections = ref({\n  added: true,\n  removed: true,\n  changed: true\n})\n\nconst addedItems = computed(() => {\n  return comparisonResult.value?.data?.added || []\n})\n\nconst removedItems = computed(() => {\n  return comparisonResult.value?.data?.removed || []\n})\n\nconst normalizeChangedItem = (item: any) => {\n  if (!item || typeof item !== 'object') return { key: null, changes: [], before: item, after: item }\n\n  const key = item.key ?? item.id ?? item.ID ?? item.code ?? item.sku ?? null\n  const changes = Array.isArray(item.changes) ? item.changes : Array.isArray(item.diff) ? item.diff : []\n  const before = item.before ?? item.rowA ?? item.a ?? item.original ?? item.from ?? item.old ?? null\n  const after = item.after ?? item.rowB ?? item.b ?? item.modified ?? item.to ?? item.new ?? null\n\n  return { ...item, key, changes, before, after }\n}\n\nconst changedItems = computed(() => {\n  const raw = comparisonResult.value?.data?.changed || []\n  return raw.map(normalizeChangedItem)\n})\n\nconst noChanges = computed(() => {\n  return addedItems.value.length === 0 && \n         removedItems.value.length === 0 && \n         changedItems.value.length === 0\n})\n\nconst toggleSection = (section: 'added' | 'removed' | 'changed') => {\n  expandedSections.value[section] = !expandedSections.value[section]\n}\n\nconst formatJson = (obj: any): string => {\n  try {\n    return JSON.stringify(obj, null, 2)\n  } catch {\n    return String(obj)\n  }\n}\n\n// Methods for parent component\nconst expandAll = () => {\n  expandedSections.value = {\n    added: true,\n    removed: true,\n    changed: true\n  }\n}\n\nconst collapseAll = () => {\n  expandedSections.value = {\n    added: false,\n    removed: false,\n    changed: false\n  }\n}\n\n// Expose methods to parent\ndefineExpose({\n  expandAll,\n  collapseAll\n})\n</script>\n","<template>\n  <div class=\"min-h-screen bg-gradient-to-br from-primary-50 to-blue-50\">\n    <!-- Header -->\n    <header class=\"bg-white shadow-sm border-b border-gray-200\">\n      <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div class=\"flex justify-between items-center py-6\">\n          <div class=\"flex items-center\">\n            <div class=\"flex-shrink-0\">\n              <svg class=\"h-8 w-8 text-primary-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n              </svg>\n            </div>\n            <div class=\"ml-4\">\n              <h1 class=\"text-2xl font-bold text-gray-900\">Excel Compare</h1>\n              <p class=\"text-sm text-gray-600\">Professional Excel file comparison tool</p>\n            </div>\n          </div>\n          \n          <div class=\"flex items-center space-x-4\">\n            <button\n              @click=\"goBack\"\n              class=\"btn-secondary\"\n            >\n              <svg class=\"h-5 w-5 mr-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 19l-7-7m0 0l7-7m-7 7h18\" />\n              </svg>\n              Upload New Files\n            </button>\n            \n            <button\n              @click=\"downloadResults\"\n              class=\"btn-primary\"\n            >\n              <svg class=\"h-5 w-5 mr-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n              </svg>\n              Download Results\n            </button>\n          </div>\n        </div>\n      </div>\n    </header>\n\n    <!-- Main Content -->\n    <main class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12\">\n      <!-- Page Header -->\n      <div class=\"text-center mb-8\">\n        <h2 class=\"text-3xl font-bold text-gray-900 mb-4\">Comparison Results</h2>\n        <p class=\"text-lg text-gray-600\">\n          Detailed analysis of differences between your Excel files\n        </p>\n      </div>\n\n      <!-- Summary Cards -->\n      <SummaryCards class=\"mb-8\" />\n\n      <!-- Results Content -->\n      <div class=\"grid lg:grid-cols-3 gap-8\">\n        <!-- Diff Viewer -->\n        <div class=\"lg:col-span-2\">\n          <div class=\"card\">\n            <div class=\"flex justify-between items-center mb-6\">\n              <h3 class=\"text-xl font-bold text-gray-900\">Detailed Changes</h3>\n              <div class=\"flex space-x-2\">\n                <button\n                  @click=\"expandAll\"\n                  class=\"text-sm text-primary-600 hover:text-primary-700\"\n                >\n                  Expand All\n                </button>\n                <button\n                  @click=\"collapseAll\"\n                  class=\"text-sm text-primary-600 hover:text-primary-700\"\n                >\n                  Collapse All\n                </button>\n              </div>\n            </div>\n            <DiffViewer />\n          </div>\n        </div>\n\n        <!-- Sidebar -->\n        <div class=\"space-y-6\">\n          <!-- File Info -->\n          <div class=\"card\">\n            <h3 class=\"text-lg font-semibold text-gray-900 mb-4\">Files Compared</h3>\n            <div class=\"space-y-3\">\n              <div\n                v-for=\"file in files\"\n                :key=\"file.id\"\n                class=\"flex items-center space-x-3 p-3 bg-gray-50 rounded-lg\"\n              >\n                <svg class=\"h-6 w-6 text-primary-600 flex-shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n                </svg>\n                <div class=\"min-w-0\">\n                  <p class=\"text-sm font-medium text-gray-900 truncate\">\n                    {{ file.name }}\n                  </p>\n                  <p class=\"text-xs text-gray-500\">\n                    {{ formatFileSize(file.size) }}\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <!-- Processing Info -->\n          <div class=\"card\">\n            <h3 class=\"text-lg font-semibold text-gray-900 mb-4\">Processing Details</h3>\n            <div class=\"space-y-2 text-sm\">\n              <div class=\"flex justify-between\">\n                <span class=\"text-gray-600\">Status:</span>\n                <span class=\"text-green-600 font-medium\">Completed</span>\n              </div>\n              <div class=\"flex justify-between\">\n                <span class=\"text-gray-600\">Method:</span>\n                <span class=\"text-gray-900\">n8n Webhook</span>\n              </div>\n              <div class=\"flex justify-between\">\n                <span class=\"text-gray-600\">Format:</span>\n                <span class=\"text-gray-900\">JSON Diff</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { useFilesStore } from '~/stores/files'\nimport { formatFileSize } from '~/utils/fileValidation'\n\nconst store = useFilesStore()\nconst files = computed(() => store.files)\nconst comparisonResult = computed(() => store.comparisonResult)\n\n// Redirect if no comparison result\nif (!comparisonResult.value) {\n  await navigateTo('/')\n}\n\nconst goBack = () => {\n  store.clearFiles()\n  navigateTo('/')\n}\n\nconst downloadResults = () => {\n  if (!comparisonResult.value) return\n  \n  const dataStr = JSON.stringify(comparisonResult.value, null, 2)\n  const dataBlob = new Blob([dataStr], { type: 'application/json' })\n  const url = URL.createObjectURL(dataBlob)\n  \n  const link = document.createElement('a')\n  link.href = url\n  link.download = `excel-comparison-${new Date().toISOString().split('T')[0]}.json`\n  document.body.appendChild(link)\n  link.click()\n  document.body.removeChild(link)\n  URL.revokeObjectURL(url)\n}\n\nconst expandAll = () => {\n  // This would be implemented in the DiffViewer component\n  console.log('Expand all')\n}\n\nconst collapseAll = () => {\n  // This would be implemented in the DiffViewer component\n  console.log('Collapse all')\n}\n</script>"],"version":3}